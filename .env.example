# GitLab
GITBOT_GITLAB_URL=https://gitlab.com
GITBOT_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITBOT_WEBHOOK_SECRET=your-webhook-secret
GITBOT_BOT_USERNAME=gitbot

# Model family: anthropic, openai, gemini, ollama, claude-code
GITBOT_LLM_FAMILY=claude-code

# Optional: override models per tier (litellm model strings)
# GITBOT_LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
# GITBOT_LLM_MODEL_MID=claude-sonnet-4-5-20241022
# GITBOT_LLM_MODEL_STRONG=claude-opus-4-20250514

# API config (not needed for claude-code family)
# GITBOT_LLM_API_BASE=http://localhost:11434  # for ollama
# GITBOT_LLM_API_KEY=sk-ant-...               # for cloud APIs

# Claude Code backend
# GITBOT_CLAUDE_CODE_PATH=claude               # path to CLI binary

# Server
GITBOT_HOST=0.0.0.0
GITBOT_PORT=8042
